# Copy to .env and fill in values. Never commit .env.
# Loaded automatically from the project root and/or ~/.config/aegis/.env

# --- OpenAI API (Realtime duplex + Chat API) ---
OPENAI_API_KEY=
# OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime

# --- LiteLLM proxy (OpenAI-compatible) ---
# LITELLM_API_KEY=sk-litellm
# Point Aegis at your proxy via settings (llm.litellm.base_url) or:
# LITELLM_BASE_URL=http://127.0.0.1:4000/v1

# --- Ollama (local; key usually unused but some clients send one) ---
# OLLAMA_API_KEY=ollama

# --- Azure OpenAI / Azure AI Foundry ---
# AZURE_OPENAI_API_KEY=
# Configure endpoint + deployment in settings (llm.azure_openai.*) or:
#   uv run aegis settings

# --- AWS Bedrock (Converse API; SigV4 — no boto3) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1
# AWS_PROFILE=default

# --- Optional: Picovoice Porcupine wake word ---
# PICOVOICE_ACCESS_KEY=

# --- Optional: default profile ---
# AEGIS_PROFILE=mvp

# ChatGPT OAuth tokens are NOT stored here — use:
#   aegis auth login
#   or Settings → Sign in with ChatGPT
# Token file: ~/.config/aegis/credentials/chatgpt_oauth.json
