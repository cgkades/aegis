# Copy to .env and fill in values. Never commit .env.
# Loaded automatically from the project root and/or ~/.config/aegis/.env

# Required for live OpenAI Realtime voice sessions
OPENAI_API_KEY=

# Optional: Picovoice Porcupine wake word
PICOVOICE_ACCESS_KEY=

# Optional: override Realtime WebSocket URL (advanced)
# OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime

# Optional: default profile when not set on CLI
# AEGIS_PROFILE=mvp
